   "source": [
    "import numpy as np\n",
    "\n",
    "L = np.sqrt(6)\n",
    "q = 2*L**0.5 \n",
    "w = 2*L\n",
    "p = 24/q \n",
    "\n",
    "print(L, q, w, p)\n",
    "\n",
    "U = 24*np.log(q) - p*q \n",
    "Pi = p*q - w*L \n",
    "Uw = w*L - L**2\n",
    "\n",
    "print(U, Pi, Uw)"
   ]
  }
